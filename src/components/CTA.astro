---
import { pl } from '../i18n/pl';
import { en } from '../i18n/en';

interface Props { lang?: 'pl' | 'en'; }
const { lang = 'pl' } = Astro.props;
const t = lang === 'en' ? en : pl;
const href = lang === 'en' ? '/en/contact' : '/kontakt';
---

<section class="bg-sky-50 border-t border-sky-100">
  <div class="max-w-3xl mx-auto px-6 py-24 text-center">
    <h2 class="text-4xl md:text-5xl font-bold text-gray-800 leading-tight" style="font-family: 'Caveat', cursive;">
      {t.cta.headline}
    </h2>
    <p class="mt-5 text-lg text-gray-500">
      {t.cta.sub}
    </p>
    <a href={href}
      class="inline-block mt-10 bg-rose-400 text-white px-8 py-4 rounded-xl text-base font-medium hover:bg-rose-500 transition-colors shadow-sm">
      {t.cta.button}
    </a>
  </div>
</section>
