---
import { pl } from '../i18n/pl';
import { en } from '../i18n/en';

interface Props { lang?: 'pl' | 'en'; }
const { lang = 'pl' } = Astro.props;
const t = lang === 'en' ? en : pl;
---

<section class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Without OneDoc -->
      <div class="rounded-2xl border border-rose-100 bg-rose-50 p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-full bg-rose-200 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-rose-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-rose-600">{t.comparison.without}</h3>
        </div>
        <ul class="space-y-4">
          {t.comparison.items.map((item) => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-rose-300 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
              </svg>
              <span class="text-sm text-rose-800 leading-relaxed">{item.without}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- With OneDoc -->
      <div class="rounded-2xl border border-sky-100 bg-sky-50 p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-full bg-sky-200 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-sky-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-sky-600">{t.comparison.with}</h3>
        </div>
        <ul class="space-y-4">
          {t.comparison.items.map((item) => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sky-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-sm text-sky-900 leading-relaxed">{item.with}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>
