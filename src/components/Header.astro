---
import { pl } from '../i18n/pl';
import { en } from '../i18n/en';

interface Props { lang?: 'pl' | 'en'; }
const { lang = 'pl' } = Astro.props;
const t = lang === 'en' ? en : pl;
const base = lang === 'en' ? '/en' : '';
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-300 shadow-md relative">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={`${base}/`} class="text-xl font-semibold tracking-tight text-sky-700">OneDoc</a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-700">
      <a href={`${base}/blog`} class="hover:text-sky-600 transition-colors">{t.nav.blog}</a>
      <a href={`${base}/portfolio`} class="hover:text-sky-600 transition-colors">{t.nav.portfolio}</a>
      <a href={lang === 'en' ? '/en/pricing' : '/cennik'} class="hover:text-sky-600 transition-colors">{t.nav.pricing}</a>
      <a href={lang === 'en' ? '/en/contact' : '/kontakt'} class="hover:text-sky-600 transition-colors">{t.nav.contact}</a>
    </nav>

    <div class="flex items-center gap-3">
      <a href={lang === 'en' ? '/' : '/en/'} class="hidden md:block text-sm text-gray-500 hover:text-sky-600 transition-colors font-medium">
        {lang === 'en' ? 'PL' : 'EN'}
      </a>
      <a href={lang === 'en' ? '/en/contact' : '/kontakt'}
        class="hidden md:block text-sm bg-rose-400 text-white px-4 py-2 rounded-lg hover:bg-rose-500 transition-colors font-medium">
        {t.hero.cta}
      </a>
      <a href="https://app.onedoc.pl/" target="_blank" rel="noopener noreferrer"
        class="hidden md:block text-sm border border-sky-300 text-sky-700 px-4 py-2 rounded-lg hover:bg-sky-50 hover:border-sky-500 transition-colors font-medium">
        {t.nav.app} →
      </a>

      <!-- Hamburger button (mobile only) -->
      <button
        id="menu-toggle"
        aria-label={lang === 'en' ? 'Open menu' : 'Otwórz menu'}
        aria-expanded="false"
        class="md:hidden flex flex-col justify-center items-center gap-1.5 w-10 h-10 rounded-lg hover:bg-gray-100 transition-colors"
      >
        <span id="bar1" class="block w-5 h-0.5 bg-gray-700 transition-all duration-300 origin-center"></span>
        <span id="bar2" class="block w-5 h-0.5 bg-gray-700 transition-all duration-300"></span>
        <span id="bar3" class="block w-5 h-0.5 bg-gray-700 transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white shadow-lg">
    <nav class="max-w-6xl mx-auto px-6 py-3 flex flex-col">
      <a href={`${base}/blog`} class="py-3 text-sm font-medium text-gray-700 hover:text-sky-600 border-b border-gray-100 transition-colors">{t.nav.blog}</a>
      <a href={`${base}/portfolio`} class="py-3 text-sm font-medium text-gray-700 hover:text-sky-600 border-b border-gray-100 transition-colors">{t.nav.portfolio}</a>
      <a href={lang === 'en' ? '/en/pricing' : '/cennik'} class="py-3 text-sm font-medium text-gray-700 hover:text-sky-600 border-b border-gray-100 transition-colors">{t.nav.pricing}</a>
      <a href={lang === 'en' ? '/en/contact' : '/kontakt'} class="py-3 text-sm font-medium text-gray-700 hover:text-sky-600 border-b border-gray-100 transition-colors">{t.nav.contact}</a>
      <div class="pt-4 pb-2 flex flex-col gap-2.5">
        <a href={lang === 'en' ? '/en/contact' : '/kontakt'}
          class="block text-center text-sm font-medium bg-rose-400 text-white px-4 py-2.5 rounded-lg hover:bg-rose-500 transition-colors">
          {t.hero.cta}
        </a>
        <a href="https://app.onedoc.pl/" target="_blank" rel="noopener noreferrer"
          class="block text-center text-sm font-medium border border-sky-300 text-sky-700 px-4 py-2.5 rounded-lg hover:bg-sky-50 transition-colors">
          {t.nav.app} →
        </a>
        <a href={lang === 'en' ? '/' : '/en/'}
          class="block text-center text-sm text-gray-500 hover:text-sky-600 py-1 transition-colors">
          {lang === 'en' ? 'Przełącz na Polski' : 'Switch to English'}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1') as HTMLElement | null;
  const bar2 = document.getElementById('bar2') as HTMLElement | null;
  const bar3 = document.getElementById('bar3') as HTMLElement | null;

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    if (bar1 && bar2 && bar3) {
      if (!isOpen) {
        bar1.style.transform = 'translateY(8px) rotate(45deg)';
        bar2.style.opacity = '0';
        bar3.style.transform = 'translateY(-8px) rotate(-45deg)';
      } else {
        bar1.style.transform = '';
        bar2.style.opacity = '';
        bar3.style.transform = '';
      }
    }
  });

  // Close menu on outside click
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    if (menu && btn && !menu.contains(target) && !btn.contains(target)) {
      if (!menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        if (bar1 && bar2 && bar3) {
          bar1.style.transform = '';
          bar2.style.opacity = '';
          bar3.style.transform = '';
        }
      }
    }
  });
</script>
