---
import { pl } from '../i18n/pl';
import { en } from '../i18n/en';

interface Props { lang?: 'pl' | 'en'; }
const { lang = 'pl' } = Astro.props;
const t = lang === 'en' ? en : pl;
const base = lang === 'en' ? '/en' : '';
---

<div class="relative overflow-hidden bg-white">

  <!-- Sketch background -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-full h-full"
      viewBox="0 0 1440 600"
      preserveAspectRatio="xMidYMid slice"
      fill="none"
      stroke="#0ea5e9"
      stroke-linecap="round"
      stroke-linejoin="round"
      opacity="0.16"
    >
      <!-- Document 1 – top left -->
      <g transform="translate(55, 85) rotate(-9)">
        <path d="M0,0 L40,0 L50,10 L50,68 L0,68 Z" stroke-width="1.6"/>
        <path d="M40,0 L40,10 L50,10" stroke-width="1.6"/>
        <line x1="8" y1="22" x2="44" y2="22" stroke-width="1.1"/>
        <line x1="8" y1="30" x2="44" y2="30" stroke-width="1.1"/>
        <line x1="8" y1="38" x2="36" y2="38" stroke-width="1.1"/>
        <line x1="8" y1="46" x2="42" y2="46" stroke-width="1.1"/>
        <line x1="8" y1="54" x2="30" y2="54" stroke-width="1.1"/>
      </g>

      <!-- Small sparkle – left edge -->
      <g transform="translate(28, 48) rotate(12)" stroke-width="1.4">
        <line x1="10" y1="0" x2="10" y2="20"/>
        <line x1="0" y1="10" x2="20" y2="10"/>
        <line x1="3" y1="3" x2="17" y2="17"/>
        <line x1="17" y1="3" x2="3" y2="17"/>
      </g>

      <!-- Question mark – left lower -->
      <g transform="translate(72, 335) rotate(-8)" stroke-width="1.8">
        <path d="M8,0 C8,0 30,-4 32,14 C34,30 18,32 18,46"/>
        <circle cx="18" cy="57" r="3" fill="#0ea5e9" stroke="none"/>
      </g>

      <!-- Checkmark in circle – centre-left top -->
      <g transform="translate(590, 22) rotate(-5)" stroke-width="1.6">
        <circle cx="28" cy="28" r="26"/>
        <path d="M14,28 L24,40 L43,16"/>
      </g>

      <!-- Curved arrow – scattered upper -->
      <g transform="translate(345, 52) rotate(16)" stroke-width="1.5">
        <path d="M0,22 Q26,0 52,22"/>
        <path d="M44,10 L52,22 L39,24"/>
      </g>

      <!-- Small plus – mid-left -->
      <g transform="translate(438, 188)" stroke-width="1.4">
        <line x1="9" y1="0" x2="9" y2="18"/>
        <line x1="0" y1="9" x2="18" y2="9"/>
      </g>

      <!-- Small document – centre top -->
      <g transform="translate(662, 28) rotate(-6)">
        <path d="M0,0 L30,0 L38,8 L38,52 L0,52 Z" stroke-width="1.4"/>
        <path d="M30,0 L30,8 L38,8" stroke-width="1.4"/>
        <line x1="6" y1="18" x2="32" y2="18" stroke-width="1.1"/>
        <line x1="6" y1="26" x2="32" y2="26" stroke-width="1.1"/>
        <line x1="6" y1="34" x2="26" y2="34" stroke-width="1.1"/>
        <line x1="6" y1="42" x2="29" y2="42" stroke-width="1.1"/>
      </g>

      <!-- Pencil – upper right -->
      <g transform="translate(838, 135) rotate(-26)" stroke-width="1.6">
        <rect x="-6" y="0" width="12" height="66" rx="1"/>
        <path d="M-6,66 L6,66 L0,84 Z"/>
        <rect x="-6" y="-13" width="12" height="13" rx="1"/>
        <line x1="-6" y1="-4" x2="6" y2="-4" stroke-width="1.2"/>
        <line x1="-6" y1="60" x2="6" y2="60" stroke-width="1.2"/>
      </g>

      <!-- Open Book – right area -->
      <g transform="translate(918, 42) rotate(7)" stroke-width="1.6">
        <path d="M0,58 L0,8 Q0,2 8,2 Q30,0 55,5 L55,63 Q30,58 8,60 Q0,61 0,58 Z"/>
        <path d="M55,5 L55,63 Q80,58 102,60 Q110,61 110,58 L110,8 Q110,2 102,2 Q80,0 55,5 Z"/>
        <line x1="55" y1="5" x2="55" y2="63" stroke-width="1.2"/>
        <line x1="9"  y1="18" x2="47" y2="16" stroke-width="1.1"/>
        <line x1="9"  y1="28" x2="47" y2="26" stroke-width="1.1"/>
        <line x1="9"  y1="38" x2="41" y2="36" stroke-width="1.1"/>
        <line x1="9"  y1="48" x2="44" y2="46" stroke-width="1.1"/>
        <line x1="63" y1="16" x2="101" y2="18" stroke-width="1.1"/>
        <line x1="63" y1="26" x2="101" y2="28" stroke-width="1.1"/>
        <line x1="63" y1="36" x2="95"  y2="38" stroke-width="1.1"/>
        <line x1="63" y1="46" x2="99"  y2="48" stroke-width="1.1"/>
      </g>

      <!-- Lightbulb – top right -->
      <g transform="translate(1158, 22) rotate(-10)" stroke-width="1.6">
        <path d="M20,56 L20,38 Q8,28 8,16 Q8,0 26,0 Q44,0 44,16 Q44,28 32,38 L32,56 Z"/>
        <line x1="20" y1="56" x2="32" y2="56" stroke-width="1.3"/>
        <line x1="20" y1="63" x2="32" y2="63" stroke-width="1.3"/>
        <line x1="22" y1="70" x2="30" y2="70" stroke-width="1.3"/>
        <line x1="48" y1="8"  x2="55" y2="1"  stroke-width="1.2"/>
        <line x1="50" y1="20" x2="58" y2="18" stroke-width="1.2"/>
        <line x1="2"  y1="8"  x2="-5" y2="1"  stroke-width="1.2"/>
      </g>

      <!-- Magnifying glass – right mid -->
      <g transform="translate(1258, 208) rotate(-12)">
        <circle cx="32" cy="32" r="28" stroke-width="1.8"/>
        <line x1="52" y1="52" x2="76" y2="76" stroke-width="4"/>
      </g>

      <!-- Document 2 – right lower -->
      <g transform="translate(1058, 328) rotate(11)">
        <path d="M0,0 L42,0 L52,10 L52,72 L0,72 Z" stroke-width="1.5"/>
        <path d="M42,0 L42,10 L52,10" stroke-width="1.5"/>
        <line x1="8" y1="22" x2="46" y2="22" stroke-width="1.1"/>
        <line x1="8" y1="31" x2="46" y2="31" stroke-width="1.1"/>
        <line x1="8" y1="40" x2="40" y2="40" stroke-width="1.1"/>
        <line x1="8" y1="49" x2="44" y2="49" stroke-width="1.1"/>
        <line x1="8" y1="58" x2="34" y2="58" stroke-width="1.1"/>
      </g>

      <!-- Gear / cog – far right -->
      <g transform="translate(1338, 358) rotate(8)">
        <circle cx="35" cy="35" r="22" stroke-width="1.5"/>
        <circle cx="35" cy="35" r="9"  stroke-width="1.5"/>
        <rect x="27" y="5"  width="16" height="10" rx="2" stroke-width="1.4"/>
        <rect x="27" y="5"  width="16" height="10" rx="2" stroke-width="1.4" transform="rotate(45,  35, 35)"/>
        <rect x="27" y="5"  width="16" height="10" rx="2" stroke-width="1.4" transform="rotate(90,  35, 35)"/>
        <rect x="27" y="5"  width="16" height="10" rx="2" stroke-width="1.4" transform="rotate(135, 35, 35)"/>
        <rect x="27" y="5"  width="16" height="10" rx="2" stroke-width="1.4" transform="rotate(180, 35, 35)"/>
        <rect x="27" y="5"  width="16" height="10" rx="2" stroke-width="1.4" transform="rotate(225, 35, 35)"/>
        <rect x="27" y="5"  width="16" height="10" rx="2" stroke-width="1.4" transform="rotate(270, 35, 35)"/>
        <rect x="27" y="5"  width="16" height="10" rx="2" stroke-width="1.4" transform="rotate(315, 35, 35)"/>
      </g>

      <!-- AI / neural nodes – bottom right -->
      <g transform="translate(1198, 455)" stroke-width="1.4">
        <circle cx="35" cy="0"  r="9"/>
        <circle cx="0"  cy="38" r="9"/>
        <circle cx="65" cy="38" r="9"/>
        <circle cx="18" cy="76" r="9"/>
        <circle cx="52" cy="76" r="9"/>
        <line x1="35" y1="9"  x2="0"  y2="29"/>
        <line x1="35" y1="9"  x2="65" y2="29"/>
        <line x1="0"  y1="47" x2="18" y2="67"/>
        <line x1="0"  y1="47" x2="52" y2="67"/>
        <line x1="65" y1="47" x2="18" y2="67"/>
        <line x1="65" y1="47" x2="52" y2="67"/>
      </g>

      <!-- Folder – centre bottom -->
      <g transform="translate(528, 488) rotate(-8)" stroke-width="1.5">
        <path d="M0,15 L0,63 Q0,67 4,67 L76,67 Q80,67 80,63 L80,19 Q80,15 76,15 L39,15 L31,6 Q29,2 25,2 L4,2 Q0,2 0,6 Z"/>
      </g>

      <!-- Cloud – left bottom -->
      <g transform="translate(178, 478) rotate(4)" stroke-width="1.5">
        <path d="M18,54 Q4,54 2,42 Q0,30 14,28 Q12,12 28,10 Q42,8 48,20 Q56,14 66,18 Q80,22 80,36 Q90,36 90,46 Q90,56 76,56 Z"/>
      </g>

      <!-- Sparkle 2 – mid right -->
      <g transform="translate(728, 88) rotate(22)" stroke-width="1.5">
        <line x1="14" y1="0"  x2="14" y2="28"/>
        <line x1="0"  y1="14" x2="28" y2="14"/>
        <line x1="4"  y1="4"  x2="24" y2="24"/>
        <line x1="24" y1="4"  x2="4"  y2="24"/>
      </g>

      <!-- Small plus – lower left scatter -->
      <g transform="translate(298, 398) rotate(10)" stroke-width="1.3">
        <line x1="8" y1="0" x2="8" y2="16"/>
        <line x1="0" y1="8" x2="16" y2="8"/>
      </g>

      <!-- Tiny sparkle – mid scatter -->
      <g transform="translate(498, 112) rotate(-5)" stroke-width="1.2">
        <line x1="8" y1="0"  x2="8"  y2="16"/>
        <line x1="0" y1="8"  x2="16" y2="8"/>
        <line x1="2" y1="2"  x2="14" y2="14"/>
        <line x1="14" y1="2" x2="2"  y2="14"/>
      </g>

      <!-- Floating dots -->
      <circle cx="148" cy="252" r="3.5" fill="#0ea5e9" stroke="none"/>
      <circle cx="902" cy="298" r="3"   fill="#0ea5e9" stroke="none"/>
      <circle cx="782" cy="492" r="3"   fill="#0ea5e9" stroke="none"/>
      <circle cx="448" cy="302" r="2.5" fill="#0ea5e9" stroke="none"/>
      <circle cx="1402" cy="148" r="3.5" fill="#0ea5e9" stroke="none"/>
      <circle cx="1142" cy="398" r="2.5" fill="#0ea5e9" stroke="none"/>
    </svg>
  </div>

  <section class="max-w-6xl mx-auto px-6 py-28 md:py-40 relative">
    <div class="max-w-3xl mx-auto text-center">
      <span class="hero-item text-sm font-medium text-sky-500 tracking-wide uppercase" style="animation-delay: 0.1s">OneDoc</span>
      <h1 class="hero-item mt-4 text-5xl md:text-6xl font-bold leading-tight text-gray-800" style="font-family: 'Caveat', cursive; animation-delay: 0.22s">
        {t.hero.headline}
      </h1>
      <p class="hero-item mt-6 text-xl text-gray-500 leading-relaxed max-w-2xl" style="animation-delay: 0.38s">
        {t.hero.sub}
      </p>
      <div class="hero-item mt-10 max-w-2xl relative rounded-2xl overflow-hidden shadow-md border border-sky-100" style="animation-delay: 0.48s; aspect-ratio: 1/1;">
        <video
          id="hero-video"
          src="/screenshots/procedury.mp4"
          autoplay
          loop
          muted
          playsinline
          class="w-full h-full object-cover"
        ></video>
        <button
          id="hero-mute-btn"
          aria-label="Toggle mute"
          class="absolute bottom-3 right-3 w-9 h-9 flex items-center justify-center rounded-full bg-black/40 hover:bg-black/60 text-white transition-colors backdrop-blur-sm"
        >
          <!-- Muted icon (shown by default) -->
          <svg id="icon-muted" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75 19.5 12m0 0 2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25m-10.5-6 4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
          </svg>
          <!-- Unmuted icon (hidden by default) -->
          <svg id="icon-unmuted" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
          </svg>
        </button>
      </div>

      <script>
        const video = document.getElementById('hero-video') as HTMLVideoElement;
        const btn = document.getElementById('hero-mute-btn');
        const iconMuted = document.getElementById('icon-muted');
        const iconUnmuted = document.getElementById('icon-unmuted');

        btn?.addEventListener('click', () => {
          video.muted = !video.muted;
          iconMuted?.classList.toggle('hidden', !video.muted);
          iconUnmuted?.classList.toggle('hidden', video.muted);
        });
      </script>
      <div class="hero-item mt-8 flex flex-wrap gap-4 justify-center" style="animation-delay: 0.62s">
        <a href={lang === 'en' ? '/en/contact' : '/kontakt'}
          class="bg-rose-400 text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-rose-500 transition-colors">
          {t.hero.cta}
        </a>
        <a href={`${base}/portfolio`}
          class="border border-sky-200 text-sky-700 px-6 py-3 rounded-lg text-sm font-medium hover:border-sky-400 hover:bg-sky-50 transition-colors">
          {t.hero.cta2}
        </a>
      </div>
    </div>
  </section>

</div>
