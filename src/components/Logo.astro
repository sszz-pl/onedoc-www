---
interface Props {
  size?: number;
}
const { size = 32 } = Astro.props;
---

<svg width={size} height={size} viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <!-- Document body -->
  <path d="M4,2 L20,2 L28,10 L28,30 Q28,30 4,30 Z" fill="#e0f2fe" stroke="none"/>
  <!-- Fold background -->
  <path d="M20,2 L20,10 L28,10 Z" fill="#bae6fd"/>
  <!-- Document outline -->
  <path d="M4,2 L20,2 L28,10 L28,30 L4,30 Z" fill="none" stroke="#38bdf8" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
  <path d="M20,2 L20,10 L28,10" fill="none" stroke="#38bdf8" stroke-width="1.5" stroke-linejoin="round"/>
  <!-- Text lines -->
  <line x1="8" y1="17" x2="23" y2="17" stroke="#7dd3fc" stroke-width="2" stroke-linecap="round"/>
  <line x1="8" y1="22" x2="23" y2="22" stroke="#7dd3fc" stroke-width="2" stroke-linecap="round"/>
  <line x1="8" y1="27" x2="16" y2="27" stroke="#7dd3fc" stroke-width="2" stroke-linecap="round"/>
  <!-- Sparkle (rose) -->
  <g transform="translate(5, 4)">
    <line x1="4.5" y1="0"   x2="4.5" y2="9"   stroke="#fb7185" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="0"   y1="4.5" x2="9"   y2="4.5" stroke="#fb7185" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="1.3" y1="1.3" x2="7.7" y2="7.7" stroke="#fb7185" stroke-width="1"   stroke-linecap="round" opacity="0.55"/>
    <line x1="7.7" y1="1.3" x2="1.3" y2="7.7" stroke="#fb7185" stroke-width="1"   stroke-linecap="round" opacity="0.55"/>
  </g>
</svg>
