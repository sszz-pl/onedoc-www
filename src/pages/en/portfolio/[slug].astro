---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { en } from '../../../i18n/en';

export async function getStaticPaths() {
  const items = await getCollection('portfolio', ({ data }) => data.lang === 'en');
  return items.map(item => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const t = en;
---

<BaseLayout title={item.data.title} description={item.data.description} lang="en">
  <article class="max-w-3xl mx-auto px-6 py-20">
    <a href="/en/portfolio" class="text-sm text-sky-400 hover:text-sky-600 transition-colors">{t.portfolio.backToPortfolio}</a>
    {item.data.image && (
      <div class="mt-8 flex items-center justify-start">
        <img src={item.data.image} alt={item.data.client ?? item.data.title} class="max-h-16 max-w-xs object-contain" />
      </div>
    )}
    {item.data.client && (
      <div class="mt-4 flex items-center gap-3">
        <p class="text-sm text-sky-500 font-medium">{item.data.client}</p>
        {item.data.website && (
          <a href={item.data.website} target="_blank" rel="noopener noreferrer"
            class="text-xs text-gray-400 hover:text-sky-500 transition-colors">
            {item.data.website.replace(/https?:\/\/(www\.)?/, '').replace(/\/$/, '')} ↗
          </a>
        )}
      </div>
    )}
    <h1 class="mt-1 text-4xl font-bold text-gray-800 leading-tight">{item.data.title}</h1>
    {item.data.tags && item.data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {item.data.tags.map((tag: string) => (
          <span class="text-xs bg-gray-100 text-gray-600 px-3 py-1 rounded-full">{tag}</span>
        ))}
      </div>
    )}
    <div class="mt-10 prose prose-gray max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
